    g1 [label="圖論問題\n[✔]"];
    g2 [label="BFS\n[✔]"];
    g3 [label="DFS\n[✔]"];
    g4 [label="圖論建模\n[!?]", style="dashed"];
  }

  subgraph cluster_shortest_path {
    label="最短路問題";
    color="#bfdbfe";
    fillcolor="#1e3a8a";
    fontname="Microsoft JhengHei";
    fontcolor="#dbeafe";
    fontsize=18;

    node [fillcolor="transparent", color="#bfdbfe"];
    sp1 [label="最短路問題\n[✔]"];
    sp2 [label="Dijkstra\n[✔]"];
    sp3 [label="Bellman Ford\n[!?]", style="dashed"];
    sp4 [label="Floyd Warshall\n[✔]"];
  }

  subgraph cluster_tree {
    label="樹論";
    color="#a5b4fc";
    fillcolor="#312e81";
    fontname="Microsoft JhengHei";
    fontcolor="#e0e7ff";
    fontsize=18;

    node [fillcolor="transparent", color="#a5b4fc"];
    tree1 [label="樹論\n[✔]"];
    tree2 [label="BFS 樹\n[!?]", style="dashed"];
    tree3 [label="DFS 樹\n[!?]", style="dashed"];
