digraph CompetitiveProgrammingSkillTree {
  graph [
    rankdir=LR,
    bgcolor="transparent",
    splines=ortho,
    nodesep=0.55,
    ranksep=1.0,
    pad=0.35,
    compound=true
  ];

  node [
    shape=rect,
    style=filled,
    fontname="Microsoft JhengHei",
    fontsize=15,
    margin="0.18,0.10",
    penwidth=1.6,
    color="#7A8A99",
    fontcolor="#ffffff"
  ];

  edge [
    color="#bacae0",
    arrowsize=0.65,
    penwidth=1.2
  ];

  subgraph cluster_cp_entry {
    label="競程入門";
    color="#86efac";
    fillcolor="#052e16";
    fontname="Microsoft JhengHei";
    fontcolor="#dcfce7";
    fontsize=18;

    node [fillcolor="transparent", color="#166534"]
    root1 [label="競程"];
    core1 [label="基礎語法\n[✪]"];
    core2 [label="陣列\n[✪]"];
    core3 [label="基礎 STL 工具\n[✪]"];
  }

  subgraph cluster_sort {
    label="排序問題";
    color="#86efac";
    fillcolor="#052e16";
    fontname="Microsoft JhengHei";
    fontcolor="#dcfce7";
    fontsize=18;

    node [fillcolor="transparent", color="#86efac"];
    sort1 [label="排序問題\n[✔]"];
    sort2 [label="交換問題\n[!?]", style="dashed"];
    sort3 [label="拓撲排序\n[?]", style="dotted"];
    sort4 [label="單調隊列\n[!?]", style="dashed"];
  }

  subgraph cluster_impl {
    label="實作題";
    color="#fdba74";
    fillcolor="#431407";
    fontname="Microsoft JhengHei";
    fontcolor="#ffedd5";
    fontsize=18;

    node [fillcolor="transparent", color="#fdba74"];
    impl1 [label="實作題\n[✔]"];
    impl2 [label="二維地圖實作\n[✔]"];
    impl3 [label="字串問題\n[!?]", style="dashed"];
    impl4 [label="六邊形地圖實作\n[✔]"]
  }

  impl2 -> impl4;

  subgraph cluster_count {
    label="計數問題";
    color="#fcd34d";
    fillcolor="#422006";
    fontname="Microsoft JhengHei";
    fontcolor="#fef3c7";
    fontsize=18;

    node [fillcolor="transparent", color="#fcd34d"];
    count1 [label="計數問題\n[✔]"];
    count4 [label="微掃描線問題\n[✔]"];
    count2 [label="等價類計數問題\n[!?]", style="dashed"];
    count3 [label="排容原理\n[✔]"];
    count5 [label="拆分子問題法\n[✔]"];
    div1 [label="分治\n[?]", style="dotted"];
  }

  count1 -> count4;

  subgraph cluster_dp {
    label="動態規劃";
