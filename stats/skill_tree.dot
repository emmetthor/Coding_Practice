    num9 [label="期望值\n[!?]", style="dashed"];
    math1 [label="數學式化簡\n[✔]"];
  }

  num1 -> num8;
  num1 -> num9;
  num8 -> math1;
  num9 -> math1;

  subgraph cluster_greedy {
    label="貪心問題";
    color="#86efac";
