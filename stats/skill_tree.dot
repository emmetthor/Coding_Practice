  num1 -> num2;
  num1 -> num3;
  num1 -> num4;
  num1 -> num5;
  num1 -> num6;
  num1 -> num7;
  num2 -> math1;
  num3 -> math1;
  num4 -> math1;
  num5 -> math1;
  num6 -> math1;
  num7 -> math1;

  gr1 -> gr2;
  gr1 -> gr3;
  gr2 -> gr4;
  gr2 -> gr5;
  gr2 -> gr6;
  gr2 -> gr7;

  seq1 -> seq2;
  seq1 -> seq3;
  seq1 -> seq4;

  ds1 -> ds2;
  ds1 -> ds3;
  ds2 -> ds5;
  ds3 -> ds4;
  ds5 -> ds6;
  ds5 -> ds7;
  ds5 -> ds8;
  ds6 -> ds9;
  ds7 -> ds10;

  enum1 -> enum2;
  enum2 -> enum3;
  enum2 -> enum4;
  enum2 -> enum5;
  enum3 -> enum6;
  enum4 -> enum6;
  enum5 -> enum6;
  enum6 -> enum7;
  enum6 -> enum8;
  enum6 -> enum10;
  enum7 -> enum9;

  bit1 -> bit2;
  bit2 -> bit3;
  bit2 -> bit4;
  bit2 -> bit5;
  bit2 -> bit6;
  bit2 -> bit7;
  bit2 -> bit8;
  bit3 -> bit9;
  bit4 -> bit9;
  bit5 -> bit9;
  bit6 -> bit9;
  bit7 -> bit9;
  bit8 -> bit9;
  bit9 -> bit10;

  search1 -> search2;
