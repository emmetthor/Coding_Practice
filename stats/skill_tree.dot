    fontname="Microsoft JhengHei";
    fontcolor="#ede9fe";
    fontsize=18;

    node [fillcolor="transparent", color="#c4b5fd"];
    dp1 [label="動態規劃\n[✔]"];
    dp2 [label="背包問題\n[!?]", style="dashed"];
    dp3 [label="分段 dp\n[✔]"];
    dp4 [label="二維地圖 dp\n[✔]"];
    dp5 [label="區間 dp\n[✔]"];
    dp6 [label="賽局 dp\n[✔]"];
    dp7 [label="狀態壓縮 dp\n[?]", style="dotted"];
    dp8 [label="記憶化搜索\n[✔]"];
    dp9 [label="LCS\n[!?]", style="dashed"];
    dp10 [label="環狀 dp\n[!?]", style="dashed"];
    dp11 [label="樹 dp\n[?]", style="dotted"];
    dp12 [label="子樹合併 dp\n[?]", style="dotted"];
    dp13 [label="有權區間排程 dp\n[!?]", style="dashed"];
    dp14 [label="數位 dp\n[!?]", style="dashed"];
    dp15 [label="dp 狀態設計\n[✔]"];
    dp16 [label="dp 優化\n[?]", style="dotted"];
  }

  dp1 -> dp8;
  dp1 -> dp15;
  dp8 -> dp11;
  dp8 -> dp14;
  dp8 -> dp5;
  dp8 -> dp7;
  dp15 -> dp2;
  dp15 -> dp3;
  dp15 -> dp4;
  dp15 -> dp9;
  dp15 -> dp10;
  dp15 -> dp13;
  dp5 -> dp6;
